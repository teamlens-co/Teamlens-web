KIMI_API_MODE=openai
KIMI_API_BASE_URL=https://api.cloudflare.com/client/v4/accounts/<account-id>/ai/v1
KIMI_GATEWAY_ID=<gateway-name>
KIMI_API_KEY=replace-me
KIMI_MODEL=@cf/moonshotai/kimi-k2.6
KIMI_TIMEOUT_SECONDS=120
KIMI_MAX_RETRIES=3
KIMI_MAX_TOKENS=4096

DATABASE_URL=postgres://teamlens:teamlens@localhost:5433/teamlens
UPLOAD_DIR=../uploads
DOCKER_UPLOAD_CONTAINER=teamlens-api-go
SQLITE_PATH=./data/screenshot_ai.sqlite3
REPORT_OUTPUT_DIR=./reports
SUMMARY_HTTP_HOST=127.0.0.1
SUMMARY_HTTP_PORT=5055
SUMMARY_MIN_SCREENSHOTS=10

POLL_INTERVAL_SECONDS=60
REPORT_TIME_LOCAL=18:00
ANALYSIS_SAMPLE_STABLE_MINUTES=5
SCREENSHOT_LOOKBACK_HOURS=24
SCREENSHOT_BATCH_LIMIT=200
MAX_IMAGE_WIDTH=896
JPEG_QUALITY=60
LOG_LEVEL=INFO

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model ActivityLog {
  id         Int       @id @default(autoincrement())
  userId     String    @map("user_id")
  sessionId  String?   @map("session_id")
  mouseMoves Int       @map("mouse_moves")
  keyPresses Int       @map("key_presses")
  isActive   Boolean   @default(false) @map("is_active")
  capturedAt DateTime? @map("captured_at") @db.Timestamptz(6)
  createdAt  DateTime  @default(now()) @map("created_at")

  @@index([sessionId, capturedAt], map: "idx_activity_session_captured")
  @@index([userId, capturedAt], map: "idx_activity_user_captured")
  @@map("activity_logs")
}

model WorkSession {
  id            String    @id
  userId        String    @map("user_id")
  clockInAt     DateTime  @map("clock_in_at") @db.Timestamptz(6)
  clockOutAt    DateTime? @map("clock_out_at") @db.Timestamptz(6)
  createdAt     DateTime  @default(now()) @map("created_at")
  updatedAt     DateTime  @updatedAt @map("updated_at")
  latitude      Float?
  longitude     Float?
  location_type String?

  @@index([userId, clockInAt], map: "idx_sessions_user_clockin")
  @@map("work_sessions")
}

model Organization {
  id                           String        @id @default(cuid())
  name                         String
  slug                         String        @unique
  createdAt                    DateTime      @default(now()) @map("created_at")
  updatedAt                    DateTime      @updatedAt @map("updated_at")
  productivityThresholdMinutes Int           @default(180) @map("productivity_threshold_minutes")
  agentTokens                  AgentToken[]
  invites                      InviteToken[]
  users                        User[]

  @@map("organizations")
}

model User {
  id                 String              @id @default(cuid())
  organizationId     String              @map("organization_id")
  fullName           String              @map("full_name")
  email              String              @unique
  passwordHash       String              @map("password_hash")
  role               UserRole
  status             UserStatus          @default(ACTIVE)
  invitedById        String?             @map("invited_by_id")
  createdAt          DateTime            @default(now()) @map("created_at")
  updatedAt          DateTime            @updatedAt @map("updated_at")
  agentTokens        AgentToken[]
  invitesCreated     InviteToken[]       @relation("InvitedBy")
  manualTimeReviews  ManualTimeRequest[] @relation("ManualTimeRequestReviewer")
  manualTimeRequests ManualTimeRequest[] @relation("ManualTimeRequestUser")
  teamMemberships    TeamMembership[]
  ownedTeams         Team[]              @relation("ManagerTeams")
  invitedBy          User?               @relation("UserInvites", fields: [invitedById], references: [id])
  invitedUsers       User[]              @relation("UserInvites")
  organization       Organization        @relation(fields: [organizationId], references: [id])

  @@map("users")
}

model ManualTimeRequest {
  id              String           @id @default(cuid())
  organizationId  String           @map("organization_id")
  userId          String           @map("user_id")
  requestedById   String           @map("requested_by_id")
  reviewedById    String?          @map("reviewed_by_id")
  startAt         DateTime         @map("start_at")
  endAt           DateTime         @map("end_at")
  durationSeconds Int              @map("duration_seconds")
  reason          String
  status          ManualTimeStatus @default(PENDING)
  reviewNote      String?          @map("review_note")
  reviewedAt      DateTime?        @map("reviewed_at")
  createdAt       DateTime         @default(now()) @map("created_at")
  updatedAt       DateTime         @updatedAt @map("updated_at")
  reviewer        User?            @relation("ManualTimeRequestReviewer", fields: [reviewedById], references: [id])
  user            User             @relation("ManualTimeRequestUser", fields: [userId], references: [id], onDelete: Cascade)

  @@index([organizationId, status])
  @@index([userId, startAt])
  @@map("manual_time_requests")
}

model Team {
  id          String           @id @default(cuid())
  name        String
  managerId   String           @map("manager_id")
  createdAt   DateTime         @default(now()) @map("created_at")
  memberships TeamMembership[]
  manager     User             @relation("ManagerTeams", fields: [managerId], references: [id])

  @@index([managerId])
  @@map("teams")
}

model TeamMembership {
  id     String @id @default(cuid())
  teamId String @map("team_id")
  userId String @map("user_id")
  team   Team   @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user   User   @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([userId])
  @@map("team_memberships")
}

model InviteToken {
  id             String       @id @default(cuid())
  organizationId String       @map("organization_id")
  invitedById    String       @map("invited_by_id")
  email          String
  role           UserRole     @default(EMPLOYEE)
  token          String       @unique
  status         InviteStatus @default(PENDING)
  expiresAt      DateTime     @map("expires_at")
  acceptedAt     DateTime?    @map("accepted_at")
  createdAt      DateTime     @default(now()) @map("created_at")
  invitedBy      User         @relation("InvitedBy", fields: [invitedById], references: [id])
  organization   Organization @relation(fields: [organizationId], references: [id])

  @@index([organizationId, email])
  @@map("invite_tokens")
}

model AgentToken {
  id             String           @id @default(cuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  tokenHash      String           @unique @map("token_hash")
  label          String?
  status         AgentTokenStatus @default(ACTIVE)
  expiresAt      DateTime         @map("expires_at")
  revokedAt      DateTime?        @map("revoked_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  organization   Organization     @relation(fields: [organizationId], references: [id])
  user           User             @relation(fields: [userId], references: [id])

  @@index([userId, status])
  @@map("agent_tokens")
}

model Screenshot {
  id                String   @id @default(cuid())
  userId            String   @map("user_id")
  sessionId         String?  @map("session_id")
  capturedAt        DateTime @map("captured_at")
  createdAt         DateTime @default(now()) @map("created_at")
  filePath          String   @map("file_path")
  activeApplication String?  @map("active_application")
  windowTitle       String?  @map("window_title")
  domain            String?
  url               String?
  employeeName      String?  @map("employee_name")
  projectName       String?  @map("project_name")

  @@index([userId, capturedAt])
  @@index([sessionId])
  @@map("screenshots")
}

model ActivityUsageLog {
  id              String             @id @default(cuid())
  organizationId  String             @map("organization_id")
  userId          String             @map("user_id")
  sessionId       String?            @map("session_id")
  targetType      ActivityTargetType @map("target_type")
  appName         String             @map("app_name")
  windowTitle     String?            @map("window_title")
  domain          String?
  url             String?
  category        ActivityCategory   @default(NEUTRAL)
  durationSeconds Int                @default(0) @map("duration_seconds")
  idleSeconds     Int                @default(0) @map("idle_seconds")
  isIdle          Boolean            @default(false) @map("is_idle")
  capturedAt      DateTime           @map("captured_at")
  createdAt       DateTime           @default(now()) @map("created_at")

  @@index([organizationId, capturedAt])
  @@index([userId, capturedAt])
  @@index([sessionId])
  @@index([targetType, appName])
  @@index([domain])
  @@index([organizationId, capturedAt], map: "activity_usage_logs_org_captured_idx")
  @@index([userId, capturedAt], map: "activity_usage_logs_user_captured_idx")
  @@map("activity_usage_logs")
}

model ClassificationRule {
  id             String             @id @default(cuid())
  organizationId String             @map("organization_id")
  targetType     ActivityTargetType @map("target_type")
  targetValue    String             @map("target_value")
  category       ActivityCategory
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  @@unique([organizationId, targetType, targetValue])
  @@unique([organizationId, targetType, targetValue], map: "classification_rules_organization_id_target_type_target_value_k")
  @@index([organizationId])
  @@map("classification_rules")
}

model LiveScreenSession {
  id             String    @id
  managerId      String    @map("manager_id")
  employeeId     String    @map("employee_id")
  organizationId String    @map("organization_id")
  sessionStart   DateTime  @default(now()) @map("session_start")
  sessionEnd     DateTime? @map("session_end")
  status         String    @default("REQUESTED")
  createdAt      DateTime  @default(now()) @map("created_at")
  updatedAt      DateTime  @updatedAt @map("updated_at")

  @@index([managerId])
  @@index([employeeId])
  @@index([organizationId])
  @@index([status])
  @@map("live_screen_sessions")
}

model ScreenRecording {
  id             String   @id @default(cuid())
  managerId      String   @map("manager_id")
  employeeId     String   @map("employee_id")
  organizationId String   @map("organization_id")
  liveSessionId  String?  @map("live_session_id")
  filePath       String   @map("file_path")
  fileSize       Int      @map("file_size")
  durationMs     Int      @map("duration_ms")
  mimeType       String   @default("video/webm") @map("mime_type")
  recordedAt     DateTime @map("recorded_at")
  createdAt      DateTime @default(now()) @map("created_at")

  @@index([managerId])
  @@index([employeeId])
  @@index([organizationId])
  @@index([recordedAt])
  @@map("screen_recordings")
}

model office_locations {
  id              String   @id
  organization_id String
  label           String   @default("Main Office")
  latitude        Float
  longitude       Float
  radius_meters   Int      @default(200)
  created_at      DateTime @default(now()) @db.Timestamptz(6)
  updated_at      DateTime @default(now()) @db.Timestamptz(6)
}

enum UserRole {
  MANAGER
  EMPLOYEE
}

enum UserStatus {
  ACTIVE
  INVITED
  DISABLED
}

enum InviteStatus {
  PENDING
  ACCEPTED
  EXPIRED
  REVOKED
}

enum AgentTokenStatus {
  ACTIVE
  REVOKED
}

enum ManualTimeStatus {
  PENDING
  APPROVED
  REJECTED
}

enum ActivityCategory {
  PRODUCTIVE
  UNPRODUCTIVE
  NEUTRAL
}

enum ActivityTargetType {
  APP
  DOMAIN
  URL
}

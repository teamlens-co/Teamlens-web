# Optional API override.
# Leave this unset in Expo LAN mode: the app will infer your computer IP from
# the Metro bundle URL and call http://<your-computer-ip>/api.
#
# Android emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2/api
#
# iOS simulator:
#   EXPO_PUBLIC_API_URL=http://localhost/api
#
# Physical device on same Wi-Fi:
#   EXPO_PUBLIC_API_URL=http://192.168.1.100/api
#
# Production:
#   EXPO_PUBLIC_API_URL=https://api.teamlens.co/api
#
# EXPO_PUBLIC_API_URL=

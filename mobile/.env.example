# API base URL — points to your nginx gateway (port 80)
# The gateway routes /api/* → Go API, /socket.io/* → Node WS
#
# Local (web / iOS simulator):
#   EXPO_PUBLIC_API_URL=http://localhost/api
#
# Android emulator:
#   EXPO_PUBLIC_API_URL=http://10.0.2.2/api
#
# Physical iPhone on same Wi-Fi (REPLACE with your machine's LAN IP):
#   EXPO_PUBLIC_API_URL=http://192.168.1.100/api
#
# Production:
#   EXPO_PUBLIC_API_URL=https://api.teamlens.co
#
EXPO_PUBLIC_API_URL=http://localhost/api

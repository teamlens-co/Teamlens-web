{
  "name": "teamlens-desktop-agent",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc && vite build",
    "preview": "vite preview",
    "tauri": "set CARGO_TARGET_DIR=C:\\tmp\\teamlens-tauri-target&& tauri",
    "tauri:dev": "set CARGO_TARGET_DIR=C:\\tmp\\teamlens-tauri-target&& tauri dev --no-watch",
    "tauri:release": "set CARGO_TARGET_DIR=C:\\tmp\\teamlens-tauri-target&& tauri build --config src-tauri/tauri.release.conf.json"
  },
  "dependencies": {
    "@tauri-apps/api": "^2",
    "@tauri-apps/plugin-opener": "^2",
    "@tauri-apps/plugin-process": "^2.3.1",
    "@tauri-apps/plugin-updater": "^2.10.1",
    "react": "^19.1.0",
    "react-dom": "^19.1.0",
    "socket.io-client": "^4.8.3"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2",
    "@types/react": "^19.1.8",
    "@types/react-dom": "^19.1.6",
    "@vitejs/plugin-react": "^4.6.0",
    "typescript": "~5.8.3",
    "vite": "^7.0.4"
  }
}

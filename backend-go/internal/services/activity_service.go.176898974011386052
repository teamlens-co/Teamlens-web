func (s *ActivityService) GetActivityTimeline(ctx context.Context, organizationID string, start, end time.Time) (*ActivityTimeline, error) {
	rows, err := s.pool.Query(ctx,
		`SELECT id, full_name, email
		 FROM users
		 WHERE organization_id = $1 AND role = 'EMPLOYEE'
		 ORDER BY full_name ASC, email ASC`,
		organizationID,
	)
	if err != nil {
		return nil, fmt.Errorf("query activity timeline users: %w", err)
	}
	defer rows.Close()

	var employees []ActivityTimelineEmployee
	for rows.Next() {
		var employee ActivityTimelineEmployee
		if err := rows.Scan(&employee.UserID, &employee.EmployeeName, &employee.Email); err != nil {
			return nil, fmt.Errorf("scan activity timeline user: %w", err)
		}
		employee.TopApps = []ActivityTimelineApp{}
		employee.Segments = []ActivitySegment{}
		employees = append(employees, employee)
	}
	if err := rows.Err(); err != nil {
		return nil, fmt.Errorf("iterate activity timeline users: %w", err)
	}

	for i := range employees {
		if err := s.fillTimelineEmployee(ctx, &employees[i], start, end); err != nil {
			return nil, err
		}
	}

	return &ActivityTimeline{
		Start:     start.UTC().Format(time.RFC3339),
		End:       end.UTC().Format(time.RFC3339),
		Employees: employees,
	}, nil
}

func (s *ActivityService) fillTimelineEmployee(ctx context.Context, employee *ActivityTimelineEmployee, start, end time.Time) error {
	sessionRows, err := s.pool.Query(ctx,
		`SELECT id, clock_in_at, clock_out_at, location_type
		 FROM work_sessions
		 WHERE user_id = $1
		   AND clock_in_at < $3
		   AND COALESCE(clock_out_at, $3) > $2
		 ORDER BY clock_in_at ASC
		 LIMIT 200`,
		employee.UserID, start, end,
	)
	if err != nil {
		return fmt.Errorf("query activity timeline sessions: %w", err)
	}
	defer sessionRows.Close()

	type sessionRow struct {
		id           string
		clockInAt    time.Time
		clockOutAt   *time.Time
		locationType *string
	}

	var sessions []sessionRow
	for sessionRows.Next() {
		var session sessionRow
		if err := sessionRows.Scan(&session.id, &session.clockInAt, &session.clockOutAt, &session.locationType); err != nil {
			return fmt.Errorf("scan activity timeline session: %w", err)
		}
		sessions = append(sessions, session)
	}
	if err := sessionRows.Err(); err != nil {
		return fmt.Errorf("iterate activity timeline sessions: %w", err)
	}
	if len(sessions) == 0 {
		return s.fillTimelineTopApps(ctx, employee, start, end)
	}

	sessionIDs := make([]string, len(sessions))
	for i, session := range sessions {
		sessionIDs[i] = session.id
	}

	logRows, err := s.pool.Query(ctx,
		`SELECT session_id, COALESCE(captured_at, created_at) AS ts, mouse_moves, key_presses
		 FROM activity_logs
		 WHERE session_id = ANY($1)
		   AND COALESCE(captured_at, created_at) >= $2
		   AND COALESCE(captured_at, created_at) <= $3
		 ORDER BY session_id, ts ASC`,
		sessionIDs, start, end,
	)
	if err != nil {
		return fmt.Errorf("query activity timeline logs: %w", err)
	}
	defer logRows.Close()

	type activityLog struct {
		sessionID  string
		timestamp  time.Time
		mouseMoves int32
		keyPresses int32
	}

	logsBySession := map[string][]ActivitySample{}
	for logRows.Next() {
		var log activityLog
		if err := logRows.Scan(&log.sessionID, &log.timestamp, &log.mouseMoves, &log.keyPresses); err != nil {
			return fmt.Errorf("scan activity timeline log: %w", err)
		}
		logsBySession[log.sessionID] = append(logsBySession[log.sessionID], ActivitySample{
			Timestamp:  log.timestamp.UnixMilli(),
			MouseMoves: log.mouseMoves,
			KeyPresses: log.keyPresses,
		})

		activeAt := log.timestamp.UTC().Format(time.RFC3339)
		if employee.FirstActiveAt == nil || activeAt < *employee.FirstActiveAt {
			employee.FirstActiveAt = &activeAt
		}
		if employee.LastActiveAt == nil || activeAt > *employee.LastActiveAt {
			employee.LastActiveAt = &activeAt
		}
	}
	if err := logRows.Err(); err != nil {
		return fmt.Errorf("iterate activity timeline logs: %w", err)
	}

	rangeStartMs := start.UnixMilli()
	rangeEndMs := end.UnixMilli()
	nowMs := time.Now().UTC().UnixMilli()
	implicitEndMs := int64(implicitEndSeconds * 1000)

	for _, session := range sessions {
		sessionStartMs := max64(session.clockInAt.UnixMilli(), rangeStartMs)
		sessionEndMs := rangeEndMs

		if session.clockOutAt != nil {
			sessionEndMs = min64(session.clockOutAt.UnixMilli(), rangeEndMs)
		} else {
			lastActivityMs := session.clockInAt.UnixMilli()
			for _, sample := range logsBySession[session.id] {
				if sample.Timestamp > lastActivityMs {
					lastActivityMs = sample.Timestamp
				}
			}
			if rangeEndMs >= nowMs-60000 && lastActivityMs >= nowMs-implicitEndMs {
				sessionEndMs = min64(nowMs, rangeEndMs)
			} else {
				sessionEndMs = min64(lastActivityMs, rangeEndMs)
			}
		}

		if sessionEndMs <= sessionStartMs {
			continue
		}

		if session.locationType != nil && *session.locationType == "manual" {
			employee.WorkSeconds += (sessionEndMs - sessionStartMs) / 1000
			continue
		}

		calc := CalculateActivitySegments(ActivityCalculationInput{
			SessionStart:         sessionStartMs,
			SessionEnd:           sessionEndMs,
			Samples:              logsBySession[session.id],
			IdleThresholdSeconds: idleThresholdSeconds,
		})
		employee.WorkSeconds += calc.WorkSeconds
		employee.ActiveSeconds += calc.ActiveSeconds
		employee.IdleSeconds += calc.IdleSeconds
		employee.MouseMoves += calc.MouseMoves
		employee.KeyPresses += calc.KeyPresses
		employee.Segments = append(employee.Segments, calc.Segments...)
	}

	if employee.WorkSeconds > 0 {
		employee.UtilizationPercent = int(math.Min(100, math.Round(float64(employee.ActiveSeconds*100)/float64(employee.WorkSeconds))))
	}
	totalInputs := employee.MouseMoves + employee.KeyPresses
	if totalInputs > 0 {
		employee.MousePercent = int(math.Round(float64(employee.MouseMoves*100) / float64(totalInputs)))
		employee.KeyboardPercent = 100 - employee.MousePercent
	}

	return s.fillTimelineTopApps(ctx, employee, start, end)
}

func (s *ActivityService) fillTimelineTopApps(ctx context.Context, employee *ActivityTimelineEmployee, start, end time.Time) error {
	rows, err := s.pool.Query(ctx,
		`SELECT COALESCE(NULLIF(app_name, ''), NULLIF(domain, ''), 'Unknown') AS name,
		        COALESCE(SUM(duration_seconds), 0)::bigint AS seconds
		 FROM activity_usage_logs
		 WHERE user_id = $1
		   AND captured_at >= $2
		   AND captured_at <= $3
		 GROUP BY COALESCE(NULLIF(app_name, ''), NULLIF(domain, ''), 'Unknown')
		 ORDER BY COALESCE(SUM(duration_seconds), 0) DESC
		 LIMIT 3`,
		employee.UserID, start, end,
	)
	if err != nil {
		return fmt.Errorf("query activity timeline top apps: %w", err)
	}
	defer rows.Close()

	var apps []ActivityTimelineApp
	for rows.Next() {
		var app ActivityTimelineApp
		if err := rows.Scan(&app.Name, &app.Seconds); err != nil {
			return fmt.Errorf("scan activity timeline top app: %w", err)
		}
		apps = append(apps, app)
	}
	if err := rows.Err(); err != nil {
		return fmt.Errorf("iterate activity timeline top apps: %w", err)
	}
	if apps == nil {
		apps = []ActivityTimelineApp{}
	}
	employee.TopApps = apps
	return nil
}

# TeamLens v2 microservice environment template
# Copy this file to .env locally. Do not commit real .env files.

# Auth
JWT_SECRET=replace-with-a-random-64-char-secret
JWT_ACCESS_TTL=12h
JWT_AGENT_TTL=30d
INVITE_TTL_HOURS=72

# Database
# Docker Compose injects postgres://teamlens:teamlens@postgres:5432/teamlens.
# Use this when running services directly on the host:
DATABASE_URL=postgres://teamlens:teamlens@localhost:5433/teamlens

# Service ports
PORT=5000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=http://localhost:4000
WEB_APP_URL=http://localhost:3000
CORS_ORIGINS=http://localhost:3000,http://localhost:1420
RECORDING_ENABLED=true
RECORDING_RETENTION_HOURS=48

# WebRTC live view ICE servers
# Keep this as one-line JSON for Docker Compose compatibility.
# STUN-only can work on the same/local network, but production Android/mobile
# live view needs a reachable Coturn TURN relay with valid credentials.
WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]}]

# Production Coturn example. Replace username/credential with real values.
# WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302","turn:turn.teamlens.co:3478?transport=udp","turn:turn.teamlens.co:3478?transport=tcp","turns:turn.teamlens.co:5349?transport=tcp"],"username":"replace-me","credential":"replace-me"}]

# Optional integrations
AGENT_DOWNLOAD_URL=
GOOGLE_PLACES_API_KEY=

# Screenshot AI / Workforce Intelligence
SCREENSHOT_AI_URL=http://screenshot-ai:5055
KIMI_API_MODE=openai
KIMI_API_BASE_URL=
KIMI_GATEWAY_ID=
KIMI_API_KEY=
KIMI_MODEL=kimi-2.6
REPORT_TIME_LOCAL=18:00
PERIODIC_INTERVAL_MINUTES=30

# Alerts
ALERT_SERVICE_URL=http://alert-service:5057
NEXT_PUBLIC_ALERT_WS_URL=ws://localhost:5057/ws
ALERT_CHECK_INTERVAL=60s
ALERT_DEFAULT_ORG_ID=

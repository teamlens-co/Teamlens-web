# =============================================================================
# TeamLens v2 — Microservice Environment
# =============================================================================

# ── JWT Secret (MUST change in production, min 32 chars) ───────────────────
JWT_SECRET=change-this-to-a-random-64-char-string-in-production
JWT_ACCESS_TTL=12h

# ── Database (Postgres) ─────────────────────────────────────────────────────
# Inside Docker Compose network, these are pre-configured.
# For local development outside Docker, use:
# DATABASE_URL=postgres://teamlens:teamlens@localhost:5432/teamlens
# (No DATABASE_URL env needed for Docker — services auto-connect to postgres)

# ── Fixed local ports ───────────────────────────────────────────────────────
PORT=5000
NEXT_PUBLIC_API_URL=http://localhost:5000
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── WebRTC ICE Servers (TURN/STUN) ──────────────────────────────────────────
# Format: JSON array of RTCIceServer objects
WEBRTC_ICE_SERVERS=[{"urls":["stun:stun.l.google.com:19302"]}]

# ── Agent Download URL (for in-app downloads) ───────────────────────────────
AGENT_DOWNLOAD_URL=

# ── Optional: Google Places API Key (for office location search) ────────────
GOOGLE_PLACES_API_KEY=
